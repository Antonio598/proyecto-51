# ─────────────────────────────────────────────────────────────
# Configuración del CRM de Seguros de Flotas
# Copia este archivo a `.env` y ajusta los valores.
# ─────────────────────────────────────────────────────────────

# --- Supabase: base de datos (PostgreSQL) ---
# Ambas cadenas están en Supabase → Project Settings → Database → Connection string.
# DATABASE_URL  = "Transaction pooler" (puerto 6543) — la usa el backend en runtime.
# DIRECT_URL    = "Direct connection"  (puerto 5432) — la usa Prisma para migrar.
DATABASE_URL=postgresql://postgres.xxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.xxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase: almacenamiento de documentos ---
# Project Settings → API. La SERVICE_ROLE key es secreta: solo backend, nunca el frontend.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_BUCKET=documentos

# --- Backend (NestJS) ---
BACKEND_PORT=3001
JWT_SECRET=cambia_este_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Modelo usado para extracción de documentos y redacción de propuestas.
CLAUDE_MODEL=claude-opus-4-8

# --- Evolution API (WhatsApp) ---  [ya existente en tu infra]
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu_api_key_evolution
EVOLUTION_INSTANCE=despacho
# Token propio para validar que los webhooks entrantes vienen de tu Evolution.
EVOLUTION_WEBHOOK_TOKEN=cambia_este_token

# --- n8n ---  [ya existente en tu infra]
# Token que n8n usa para llamar endpoints protegidos del backend (cron de cobranza).
N8N_SERVICE_TOKEN=cambia_este_token_de_servicio
