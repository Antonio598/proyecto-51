{
  "name": "crm-seguros-flotas",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestión integral (CRM) para despacho de seguros de flotas de transporte de carga",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace @crm/backend",
    "dev:frontend": "npm run dev --workspace @crm/frontend",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:resolve": "prisma migrate resolve --applied 20260722000000_init --schema prisma/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
